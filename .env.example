# TikTok Developer App Credentials
# Register at https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# OAuth callback (auto-detected on Vercel, set for local dev)
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Token encryption passphrase (change this!)
TOKEN_ENCRYPTION_KEY=change-this-to-a-secure-passphrase

# Data collection settings
COLLECTION_INTERVAL_HOURS=6

# Optional: Vercel Cron secret for securing cron endpoint
CRON_SECRET=

# Optional: TikTok username for unofficial API fallback
TIKTOK_USERNAME=
